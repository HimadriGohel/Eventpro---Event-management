# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/eventpro

# Redis (used by cache + BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-access-please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-please
JWT_REFRESH_EXPIRES_IN=7d

# Cookie (refresh token)
COOKIE_NAME=ep_rt
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Bcrypt
BCRYPT_ROUNDS=10

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=600

# Admin seed (on first boot if users collection is empty)
SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@eventpro.io
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=EventPro Admin
